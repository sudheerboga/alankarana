# ─── Firebase (client) ───────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase (admin SDK for SSR) ────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single line, escape newlines in the private key as \n
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ─── Cloudinary ──────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ─── App config ──────────────────────────────────────────────
# WhatsApp business number, no +, no spaces (e.g. 919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Admin email (whoever logs into Firebase will need this in admins/{uid})
NEXT_PUBLIC_ADMIN_EMAIL=admin@alankarana.com

# Public site URL for OG share previews (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://alankarana.com
